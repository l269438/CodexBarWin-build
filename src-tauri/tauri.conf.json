{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodexPilot",
  "mainBinaryName": "CodexPilot",
  "version": "0.1.4",
  "identifier": "com.codexapiswitcher.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev:renderer",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:renderer",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CodexPilot",
        "width": 390,
        "height": 760,
        "minWidth": 390,
        "maxWidth": 390,
        "minHeight": 660,
        "resizable": true,
        "maximizable": false
      },
      {
        "label": "usage-bubble",
        "title": "CodexPilot 额度",
        "url": "/?view=usage-bubble",
        "width": 430,
        "height": 306,
        "visible": false,
        "decorations": false,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/codexpilot-icon.png",
      "icons/codexpilot-icon.icns",
      "icons/codexpilot-icon.ico"
    ]
  }
}
